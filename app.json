{
  "expo": {
    "name": "poc-face-match",
    "slug": "poc-face-match",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "İki fotoğrafı karşılaştırabilmek için galerine erişim gerekiyor."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.utqute.pocfacematch"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "İki fotoğrafı karşılaştırabilmek için galerine erişim gerekiyor."
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableAndroidGpuLibraries": [
            "libOpenCL.so",
            "libOpenCL-pixel.so"
          ],
          "enableCoreMLDelegate": true
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Galerideki fotoğrafları tarayıp yüz eşleştirebilmek için erişim gerekiyor."
        }
      ],
      "expo-sqlite",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "700cdf52-753c-45e8-b943-1fdf23975bcd"
      }
    }
  }
}
